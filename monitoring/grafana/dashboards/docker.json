        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(rate(container_network_transmit_bytes_total{name!=\"\"}[5m])) by (name)",
        "legendFormat": "Tx {{name}}"
      }],
      "title": "Xarxa per contenidor (bytes/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short",
          "custom": { "displayMode": "auto" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "CPU %" }, "properties": [{ "id": "unit", "value": "percent" }] },
          { "matcher": { "id": "byName", "options": "RAM" },   "properties": [{ "id": "unit", "value": "bytes"   }] }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": {
        "footer": { "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
