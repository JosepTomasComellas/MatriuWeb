      "options": { "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(rate(container_network_receive_bytes_total{name!=\"\"}[5m])) by (name)",
