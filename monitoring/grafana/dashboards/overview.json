{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Host",        "url": "/grafana/d/mw-host",   "type": "link", "targetBlank": false },
    { "title": "Contenidors", "url": "/grafana/d/mw-docker", "type": "link", "targetBlank": false },
    { "title": "Redis",       "url": "/grafana/d/mw-redis",  "type": "link", "targetBlank": false }
  ],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]},
          "unit": "percent", "max": 100, "min": 0,
          "mappings": []
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": ""
      }],
      "title": "CPU host",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]},
          "unit": "percent", "max": 100, "min": 0
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
        "legendFormat": ""
      }],
      "title": "RAM host",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]},
          "unit": "percent", "max": 100, "min": 0
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100)",
        "legendFormat": ""
      }],
      "title": "Disc host (/)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]},
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "web" },            "properties": [{ "id": "displayName", "value": "MatriuWeb" }] },
          { "matcher": { "id": "byName", "options": "redis-exporter" }, "properties": [{ "id": "displayName", "value": "Redis"     }] }
        ]
      },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "up",
        "legendFormat": "{{job}}"
      }],
      "title": "Serveis actius",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }
          ]},
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "redis_connected_clients",
        "legendFormat": ""
      }],
      "title": "Clients Redis",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 8 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU host"
      },{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
        "legendFormat": "RAM host"
      },{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(rate(container_cpu_usage_seconds_total{name=\"matriuweb-web\"}[5m])) * 100",
        "legendFormat": "CPU MatriuWeb"
      }],
      "title": "Tendència CPU & RAM",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 8 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 7,
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(http_requests_received_total[5m])",
        "legendFormat": "HTTP req/s ({{method}} {{path}})"
      }],
      "title": "HTTP MatriuWeb (req/s)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["matriuweb", "overview"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Overview — MatriuWeb",
  "uid": "mw-overview",
  "version": 1
}
