@page "/"
@page "/dashboard"
@rendermode InteractiveServer
@inject IFrameConfigurationService ConfigService
@inject IDashboardStateService DashState
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>MatriuWeb — Dashboard</PageTitle>

@if (_loading)
{
    <div class="skeleton-grid">
        @for (int i = 0; i < 4; i++)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Style="height:100%; border-radius:8px;" />
        }
    </div>
}
else if (_profile != null)
{
    var frames = _profile.EnabledFrames;
    var focused = DashState.FocusedFrameId;

    @if (focused == null)
    {
        <div class="frame-grid" style="@GridStyle(frames.Count)">
            @foreach (var frame in frames)
            {
                <div class="frame-card">
                    <div class="frame-header">
                        <span class="frame-title" title="@frame.Url">@frame.Title</span>
                        <div class="frame-actions">
                            <MudIconButton Icon="@Icons.Material.Filled.OpenInFull"
                                           Size="Size.Small" Color="Color.Default"
                                           Title="Vista enfocada"
                                           OnClick="() => DashState.FocusFrame(frame.Id)" />
                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                           Size="Size.Small" Color="Color.Default"
                                           Title="Obrir en nova pestanya"
                                           OnClick="() => OpenExternal(frame.Url)" />
                        </div>
                    </div>
                    <FramePanel Frame="@frame" Paused="@DashState.IsRefreshPaused" />
                </div>
            }
        </div>
    }
    else
    {
        var main = frames.FirstOrDefault(f => f.Id == focused);
        var rest = frames.Where(f => f.Id != focused).ToList();

        <div class="focus-layout">
            <div class="focus-main">
                @if (main != null)
                {
                    <div class="frame-card frame-card--focused">
                        <div class="frame-header">
                            <span class="frame-title" title="@main.Url">@main.Title</span>
                            <div class="frame-actions">
                                <MudIconButton Icon="@Icons.Material.Filled.CloseFullscreen"
                                               Size="Size.Small" Color="Color.Default"
                                               Title="Tornar a la matriu"
                                               OnClick="() => DashState.FocusFrame(null)" />
                                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                               Size="Size.Small" Color="Color.Default"
                                               Title="Obrir en nova pestanya"
                                               OnClick="() => OpenExternal(main.Url)" />
                            </div>
                        </div>
                        <FramePanel Frame="@main" Paused="@DashState.IsRefreshPaused" />
                    </div>
                }
            </div>

            <div class="focus-sidebar">
                @foreach (var frame in rest)
                {
                    <div class="frame-card frame-card--small" @onclick="() => DashState.FocusFrame(frame.Id)">
                        <div class="frame-header">
                            <span class="frame-title frame-title--small">@frame.Title</span>
                        </div>
                        <FramePanel Frame="@frame" Paused="true" Small="true" />
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    private FrameProfile? _profile;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        DashState.StateChanged += OnStateChanged;
        _profile = await ConfigService.GetActiveProfileAsync();
        _loading = false;
    }

    private void OnStateChanged() => InvokeAsync(async () =>
    {
        _profile = await ConfigService.GetActiveProfileAsync();
        StateHasChanged();
    });

    private static string GridStyle(int count) => count switch
    {
        1 => "grid-template-columns:1fr; grid-template-rows:1fr;",
        2 => "grid-template-columns:1fr 1fr; grid-template-rows:1fr;",
        3 => "grid-template-columns:1fr 1fr; grid-template-rows:1fr 1fr;",
        4 => "grid-template-columns:1fr 1fr; grid-template-rows:1fr 1fr;",
        5 => "grid-template-columns:1fr 1fr 1fr; grid-template-rows:1fr 1fr;",
        6 => "grid-template-columns:1fr 1fr 1fr; grid-template-rows:1fr 1fr;",
        _ => "grid-template-columns:repeat(3, 1fr); grid-template-rows:auto;"
    };

    private async Task OpenExternal(string url) =>
        await JS.InvokeVoidAsync("matriuWeb.openTab", url);

    public void Dispose() => DashState.StateChanged -= OnStateChanged;
}
