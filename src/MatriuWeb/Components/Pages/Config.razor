@page "/config"
@rendermode InteractiveServer
@inject IFrameConfigurationService ConfigService
@inject IBackupService BackupService
@inject ISnackbar Snackbar

<PageTitle>MatriuWeb — Configuració</PageTitle>

<div style="padding:24px; max-width:1100px; margin:0 auto;">

    <MudText Typo="Typo.h5" Style="color:#f1f5f9; margin-bottom:24px;">Configuració</MudText>

    @if (_config != null)
    {
        <MudTabs Elevation="0" ApplyEffectsToContainer="true" PanelClass="pa-4"
                 Style="background:transparent;">

            <MudTabPanel Text="Perfils i frames">
                <ProfilesPanel Config="_config"
                               OnSaved="ReloadConfig"
                               OnError="ShowError" />
            </MudTabPanel>

            <MudTabPanel Text="Importar / Exportar">
                <ImportExportPanel Config="_config"
                                   OnSaved="ReloadConfig"
                                   OnError="ShowError" />
            </MudTabPanel>

            <MudTabPanel Text="Backups">
                <BackupsPanel OnRestored="ReloadConfig"
                              OnError="ShowError" />
            </MudTabPanel>

        </MudTabs>
    }
    else
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
</div>

@code {
    private FrameConfig? _config;

    protected override async Task OnInitializedAsync()
    {
        _config = await ConfigService.GetConfigAsync();
    }

    private async Task ReloadConfig()
    {
        _config = await ConfigService.GetConfigAsync();
        Snackbar.Add("Configuració desada", Severity.Success);
        StateHasChanged();
    }

    private void ShowError(string msg) => Snackbar.Add(msg, Severity.Error);
}
